{
  "name": "bandwidth-budget-tracker",
  "version": "0.1.0",
  "description": "Privacy-first browser extension to monitor and manage bandwidth usage",
  "type": "module",
  "main": "ByteGuard-bandwidth-budget-tracker/background/service-worker.js",
  "scripts": {
    "build": "node config/build.cjs",
    "watch": "node config/build.cjs",
    "lint": "eslint \"ByteGuard-bandwidth-budget-tracker/**/*.js\" \"config/**/*.cjs\" \"tests/**/*.js\"",
    "format": "prettier --write \"ByteGuard-bandwidth-budget-tracker/**/*.{js,css,html,json}\" \"docs/**/*.{html,md}\" \"config/**/*.cjs\"",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js",
    "pack:chrome": "npm run build && node config/pack.cjs"
  },
  "keywords": [
    "bandwidth",
    "data-usage",
    "network-monitor",
    "chrome-extension",
    "privacy"
  ],
  "author": "Gautam Sukhani",
  "license": "MIT",
  "devDependencies": {
    "eslint": "^9.39.2",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "webextension-polyfill": "^0.12.0"
  },
  "dependencies": {
    "chart.js": "^4.5.1"
  }
}
